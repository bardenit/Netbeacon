snmp_default_community: public
snmp_version: 2c
poll_interval_minutes: 15        # full poll (FDB/ARP/VLAN/LLDP) while UI is open

# Adaptive polling — cadence relaxes automatically when no browser is watching.
# fast_poll_seconds: 60          # interface-status poll while UI is open (0 = disable adaptive mode)
# idle_poll_interval_minutes: 60 # full poll when nobody is watching
# idle_status_poll_minutes: 5    # status poll when nobody is watching (keeps down-alerts timely)

# Alert notifications (optional)
# alerts:
#   enabled: true
#   on_events: [device_down, device_up, device_degraded]
#   rate_limit_minutes: 60        # min time between same alert for same device
#   webhook_url: https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
#   email:
#     smtp_host: smtp.gmail.com
#     smtp_port: 587
#     smtp_user: you@gmail.com
#     smtp_password: yourapppassword
#     from: netbeacon@example.com
#     to: [admin@example.com, oncall@example.com]
#     tls: true

devices:
  - hostname: core-sw-01
    ip: 192.168.1.1
    snmp_community: public

  - hostname: access-sw-02
    ip: 192.168.1.2
    snmp_community: public
    ssh_enabled: true
    ssh_username: admin
    ssh_password: changeme

  - hostname: netgear-sw-03
    ip: 192.168.1.3
    snmp_community: public
